# Configuration du serveur
PORT=5000
NODE_ENV=production

# Configuration de la base de données MySQL (Aiven Cloud)
DB_HOST=your-host.aivencloud.com
DB_PORT=3306
DB_NAME=gestipc
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_SSL=true

# Sécurité (JWT)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=1d

# URL du frontend (pour CORS)
FRONTEND_URL=https://gestipc.vercel.app
